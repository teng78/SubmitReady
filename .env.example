# Copy to .env for local overrides. Never put real secrets in Git.
# For local backend development, copy this file to backend/.env.
SUBMITREADY_DATA_DIR=./data
SUBMITREADY_BUILTIN_RULES_DIR=../examples/rules
SUBMITREADY_DATABASE_URL=sqlite:///data/submitready.db
SUBMITREADY_MAX_UPLOAD_BYTES=20971520
SUBMITREADY_MAX_ZIP_FILES=2000
SUBMITREADY_MAX_EXTRACTED_BYTES=104857600
SUBMITREADY_OUTPUT_LIMIT=16384
SUBMITREADY_ALLOW_UNTRUSTED_EXECUTION=false
